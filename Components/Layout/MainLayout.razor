@inherits LayoutComponentBase

<div class="page">
    <main>
        @Body
    </main>
</div>

<style>
    /* บังคับซ่อน Sidebar, Nav และแถบด้านบนของระบบเดิม */
    .sidebar, .top-row, nav, [role="navigation"], .navbar-toggler {
        display: none !important;
    }

    /* ปรับให้เนื้อหาหลักชิดขอบและเต็มจอ 100% */
    .main {
        padding: 0 !important;
    }

    .content {
        padding: 0 !important;
    }

    /* ลบขอบขาวรอบๆ หน้าเว็บ */
    body {
        margin: 0;
        padding: 0;
    }
</style>