@page "/"
@rendermode InteractiveServer

<div class="app-viewport">
    <div class="mobile-container">
        @if (currentStep == 1)
        {
            <div class="screen welcome-screen" @onclick="NextStep">
                <div class="white-border-frame">
                    <div class="center-content">
                        <h1 class="main-title">Information channel Safety</h1>
                        <h2 class="sub-title">ช่องทางการติดต่อแผนกเซฟตี้</h2>
                        <div class="blink-hint">แตะเพื่อดำเนินการต่อ</div>
                    </div>
                </div>
            </div>
        }
        else if (currentStep == 2)
        {
            <div class="screen welcome-screen">
                <div class="white-border-frame">
                    <div class="menu-layout">
                        <div class="header-selection">
                            <h2 class="title-white">เลือกช่องทางการติดต่อ</h2>
                            <p class="subtitle-white">Choose Contact Channel</p>
                        </div>

                        <div class="btn-stack">
                            <div class="glow-border-box" @onclick='() => ShowList("WG")'>
                                <div class="moving-glow"></div>
                                <div class="inner-btn">
                                    <span class="static-text">WG</span>
                                </div>
                            </div>

                            <div class="glow-border-box" @onclick='() => ShowList("BP")'>
                                <div class="moving-glow"></div>
                                <div class="inner-btn">
                                    <span class="static-text">BP</span>
                                </div>
                            </div>
                        </div>

                        <button class="minimal-back-btn" @onclick="() => currentStep = 1">ย้อนกลับ (Back)</button>
                    </div>
                </div>
            </div>
        }
        else if (currentStep == 3)
        {
            <div class="screen list-screen">
                <div class="nav-header">
                    <button class="back-btn" @onclick="GoBack">BACK</button>
                    <span class="header-name">CONTACT: @selectedGroup</span>
                </div>
                <div class="scroll-list">
                    @foreach (var p in people)
                    {
                        <div class="safety-card">
                            <div class="avatar-part">
                                <img src="@p.Img" class="img-circle" />
                            </div>
                            <div class="content-part">
                                <div class="white-data">
                                    @* แสดงแค่ Area และ ชื่อ *@
                                    <p style="font-size: 12px; color: #666;"><b>Area:</b> @p.Area</p>
                                    <p style="font-size: 14px; font-weight: 700;">@p.Name</p>
                                    <p style="font-size: 12px; color: #0284c7; font-weight: 500;">
                                        <i class="fa-solid fa-envelope" style="font-size: 10px;"></i> @p.Email
                                    </p>
                                </div>
                                <div class="action-grid">
                                    @* ปุ่มโทรยังทำงานได้ปกติโดยใช้ข้อมูลจาก p.Tel แม้จะไม่โชว์เบอร์ *@
                                    <a href="tel:@p.Tel" class="btn-call">
                                        <i class="fa-solid fa-phone-volume fa-shake"></i> 📞
                                    </a>
                                    <a href="https://line.me/ti/p/~@p.Line" class="btn-line">LINE</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

